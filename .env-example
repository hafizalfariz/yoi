# Model selection:
# - pt: use .pt weights at MODEL_PT_PATH
# - openvino: use OpenVINO export directory at MODEL_OPENVINO_DIR
MODEL_TYPE=pt
MODEL_PT_PATH=models/pt/best.pt
MODEL_OPENVINO_DIR=models/openvino
VIDEO_FOLDER=video
OUTPUT_FOLDER=output
# Optional inference settings
CONF=0.25
IOU=0.45
TRACK_CONF=0.5
TRACK_IOU=0.5
# Live preview window (true/false)
SHOW_LIVE=true
# Live preview window options
# Set both width/height to 0 for auto size
SHOW_LIVE_WIDTH=1280
SHOW_LIVE_HEIGHT=720
# Fullscreen (true/false) overrides width/height
SHOW_LIVE_FULLSCREEN=false
# Stop processing when preview window is closed (true/false)
SHOW_LIVE_STOP_ON_CLOSE=true
# OpenVINO export options
EXPORT_IMGSZ=640
EXPORT_HALF=false
